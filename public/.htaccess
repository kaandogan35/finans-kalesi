# Finans Kalesi — Apache URL Yönlendirme Kuralları
#
# İki iş yapıyor:
# 1. /api/ ile başlayan istekler → PHP backend (index.php)
# 2. Diğer istekler → React frontend (frontend-build/index.html)

# Ana sayfa önceliği: önce index.html (landing page), sonra index.php (API)
DirectoryIndex index.html index.php

# URL yeniden yazma motorunu aç
RewriteEngine On

# Authorization başlığını PHP'ye ilet (PHP-CGI/FastCGI için zorunlu)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ─── 1. API İSTEKLERİ → index.php ───────────────────────────
# /api/ ile başlayan tüm istekler PHP backend'e gider
RewriteRule ^api(/.*)?$ index.php [QSA,L]

# ─── 2. GERÇEK DOSYALAR → Doğrudan sun ──────────────────────
# CSS, JS, resim gibi gerçek dosyalar varsa dokunma
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ─── 3. Frontend asset'leri → frontend-build klasöründen sun ─
# /assets/ isteklerini frontend-build/assets/ klasörüne yönlendir
RewriteRule ^assets/(.*)$ frontend-build/assets/$1 [L]

# ─── 4. DİĞER HER ŞEY → React SPA ──────────────────────────
# React Router'ın çalışması için tüm sayfaları index.html'e yönlendir
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ frontend-build/index.html [QSA,L]

# Güvenlik: .env ve gizli dosyalara erişimi engelle
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# PHP hata gösterimini kapat (production güvenliği)
php_flag display_errors Off
php_flag log_errors On
