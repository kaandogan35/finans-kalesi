# Finans Kalesi — Apache URL Yönlendirme Kuralları
#
# İki iş yapıyor:
# 1. /api/ ile başlayan istekler → PHP backend (index.php)
# 2. Diğer istekler → React frontend (frontend-build/index.html)

# Ana sayfa önceliği: önce index.html (landing page), sonra index.php (API)
DirectoryIndex index.html index.php

# URL yeniden yazma motorunu aç
RewriteEngine On

# Authorization başlığını PHP'ye ilet (PHP-CGI/FastCGI için zorunlu)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ─── 1. API İSTEKLERİ → index.php ───────────────────────────
# /api/ ile başlayan tüm istekler PHP backend'e gider
RewriteRule ^api(/.*)?$ index.php [QSA,L]

# ─── 2. GERÇEK DOSYALAR → Doğrudan sun ──────────────────────
# CSS, JS, resim gibi gerçek dosyalar varsa dokunma
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ─── 3. Frontend asset'leri → frontend-build klasöründen sun ─
# /assets/ isteklerini frontend-build/assets/ klasörüne yönlendir
RewriteRule ^assets/(.*)$ frontend-build/assets/$1 [L]

# ─── 4. LANDING PAGE — Clean URL'ler (.html uzantısız) ───────
# /ozellikler → ozellikler.html, /fiyatlar → fiyatlar.html vb.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# ─── 5. Blog dizini ve yazıları ──────────────────────────────
RewriteRule ^blog/?$ blog/index.html [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([^/]+)/?$ blog/$1.html [L]

# ─── 6. DİĞER HER ŞEY → React SPA ──────────────────────────
# React Router'ın çalışması için tüm sayfaları index.html'e yönlendir
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ frontend-build/index.html [QSA,L]

# Güvenlik: .env ve gizli dosyalara erişimi engelle
# NOT: .well-known/ iOS Universal Links ve Android App Links için herkese açık olmalı
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# .well-known dizinini aç — App Links/Universal Links için zorunlu
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/\.well-known/
    RewriteRule ^ - [L]
</IfModule>

# PHP hata gösterimini kapat (production güvenliği)
# Not: php_flag sadece mod_php ile çalışır, CGI/FastCGI'da 500 hatası verir
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /home/goparam/logs/php_error.log
</IfModule>

# CGI/FastCGI için error_log yolu (mod_php yoksa bu geçerli)
<IfModule !mod_php.c>
    SetEnv PHP_VALUE "error_log=/home/goparam/logs/php_error.log"
</IfModule>

# error_log dosyasına dışarıdan erişimi engelle (ek güvenlik)
<Files "error_log">
    Require all denied
</Files>
