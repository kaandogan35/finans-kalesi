# Finans Kalesi — Apache URL Yonlendirme Kurallari

# URL yeniden yazma motorunu ac
RewriteEngine On

# Gercekten var olan dosyalara dokunma
RewriteCond %{REQUEST_FILENAME} !-f
# Gercekten var olan klasorlere dokunma
RewriteCond %{REQUEST_FILENAME} !-d

# Geri kalan her seyi index.php'ye yonlendir
RewriteRule ^(.*)$ index.php [QSA,L]
