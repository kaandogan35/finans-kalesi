# Finans Kalesi — Gizli Ayarlar Şablonu
# Bu dosyayı ".env" olarak kopyala ve gerçek değerleri yaz
# ÖNEMLİ: .env dosyasını asla Git'e yükleme!

# Veritabanı Ayarları
DB_HOST=localhost
DB_NAME=kaandgntt_yon_saas
DB_USER=kaandgntt_yon_saas_usr
DB_PASS=buraya_gercek_sifre

# JWT (Token) Ayarları
JWT_SECRET=buraya_uzun_rastgele_bir_metin_yaz_en_az_32_karakter
JWT_ISSUER=finans-kalesi-api
JWT_ACCESS_SURESI=900
JWT_REFRESH_SURESI=604800

# Uygulama Ayarları
APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.hirdavatduragi.shop

# CORS (Hangi adreslerden istek kabul edilsin)
CORS_ORIGIN=https://app.hirdavatduragi.shop

# Şifreleme (Kozmik Oda)
CRYPTO_SALT=buraya_rastgele_salt_degeri
