  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:init": "npx cap init ParamGo com.paramgo.app --web-dir ../public/frontend-build",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "mobile:build": "vite build && npx cap sync",
    "mobile:ios": "vite build && npx cap sync ios && npx cap open ios",
    "mobile:android": "vite build && npx cap sync android && npx cap open android"
  },
